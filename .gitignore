# ─── External repos / large downloads ────────────────────────────────────────
whisper.cpp/
speech_commands/
speech_commands_v0.02.tar.gz

# ─── Python tooling ───────────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# ─── ML model artefacts (regenerate from training / conversion scripts) ────────
# NOTE: gitignore patterns must not carry inline comments — trailing text becomes
# part of the pattern and it silently never matches.
# TFLite flatbuffers — convert_to_tflite.py
*.tflite
# scikit-learn / surrogate snapshots — regenerate with fit_surrogate.py
*.joblib

# ─── Firmware & cross-compiled binaries ──────────────────────────────────────
firmware/**/*.o
firmware/**/*.elf
firmware/**/*.bin
# Host-side test binary produced by `make host` (no extension, platform-native ELF)
firmware/tinyengine_port/test_infer_host

# ─── Verilator simulation build artefacts ────────────────────────────────────
sim/verilator/obj_dir/
sim/verilator/sim_picorv32
sim/verilator/sim_picorv32_debug
sim/verilator/sim_out.vcd
rtl/tb/obj_dir/

# ─── ORFS physical-design flow outputs ───────────────────────────────────────
# All ORFS build output goes to runs/ (WORK_HOME); make/ holds only source configs.
physical/orfs/runs/
# Staged RTL copies (make/src/) and per-variant config/constraint files stay in
# make/ so DESIGN_HOME=. in config_*.mk resolves correctly, but are not committed.
physical/orfs/make/src/
# Per-variant config/constraint files generated by the optimizer for each
# (design, LANES, ACC_W, clock) point — config_L<n>... or config_<design>_L<n>...
# The hand-written base files (config.mk / constraint.sdc, no underscore) are NOT matched.
physical/orfs/make/**/config_*.mk
physical/orfs/make/**/constraint_*.sdc

# ─── Optimizer runtime outputs ────────────────────────────────────────────────
# Matches results.jsonl, results_physical.jsonl, and any future variants
optimizer/results*.jsonl
optimizer/__pycache__/
# Raw per-campaign JSONL files written directly into optimizer/ root or repo root by the runner.
# Curated copies live in optimizer/campaigns/<design>/<platform>/ and ARE committed.
optimizer/funnel_campaign_*.jsonl
funnel_campaign_*.jsonl
*_run[0-9]*.jsonl
# Visualization artifacts (optimizer/viz): generated HTML reports and the
# JournalStorage files optuna-dashboard reads. Regenerated from the JSONL logs.
# Scoped to optimizer root only — reports inside campaigns/ are committed as-is.
optimizer/report_*.html
*.optuna-journal
# Generated comparison/campaign renders (HTML + layout PNGs) — large and rebuilt
# from the committed results/*.jsonl by viz/report.py and viz/comparison.py.
optimizer/reports/

# ─── Review / scratch ─────────────────────────────────────────────────────────
review/
review.zip

# ─── Claude Code tooling ──────────────────────────────────────────────────────
.claude/worktrees/
